<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sber2Excel.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="Sber2Excel.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="Sber2Excel — Конвертер выписки Сбербанка"
        MinWidth="800" MinHeight="500"
        Width="1100" Height="700">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">

                <Button Command="{Binding OpenPdfCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📂" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Открыть PDF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Width="1"
                           Background="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="4,2"/>

                <Button Command="{Binding ExportCsvCommand}"
                        IsEnabled="{Binding HasData}"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📄" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Экспорт в CSV" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ExportXlsxCommand}"
                        IsEnabled="{Binding HasData}"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Экспорт в Excel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="⏳ Обработка…"
                           IsVisible="{Binding IsBusy}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Summary panel (visible when data is loaded) -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasData}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,4">
                    <TextBlock Text="Владелец счёта" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Statement.AccountHolder}"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,16,4">
                    <TextBlock Text="Счёт / Карта" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Statement.CardNumber}" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,16,4">
                    <TextBlock Text="Период" FontSize="11" Opacity="0.6"/>
                    <TextBlock FontWeight="SemiBold">
                        <Run Text="{Binding Statement.PeriodFrom, StringFormat=dd.MM.yyyy}"/>
                        <Run Text=" – "/>
                        <Run Text="{Binding Statement.PeriodTo, StringFormat=dd.MM.yyyy}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="Операций" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Transactions.Count}" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,0">
                    <TextBlock Text="Остаток на начало" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Statement.OpeningBalance, StringFormat={}{0:N2}}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,16,0">
                    <TextBlock Text="Пополнение" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Statement.Deposits, StringFormat={}{0:N2}}"
                               FontWeight="SemiBold" Foreground="#1A7F37"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,16,0">
                    <TextBlock Text="Списание" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Statement.Withdrawals, StringFormat={}{0:N2}}"
                               FontWeight="SemiBold" Foreground="#CF1322"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="1">
                    <TextBlock Text="Остаток на конец" FontSize="11" Opacity="0.6"/>
                    <TextBlock Text="{Binding Statement.ClosingBalance, StringFormat={}{0:N2}}"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasData}"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">

                <TextBlock Text="Категория:" VerticalAlignment="Center" Opacity="0.7"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding CategoryFilter, Mode=TwoWay}"
                          PlaceholderText="(все)"
                          MinWidth="180"/>

                <TextBlock Text="Описание:" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                <TextBox Text="{Binding DescriptionFilter, Mode=TwoWay}"
                         Watermark="поиск…"
                         MinWidth="220"/>

                <Button Command="{Binding ClearFilterCommand}"
                        IsEnabled="{Binding HasActiveFilter}"
                        Padding="10,4"
                        ToolTip.Tip="Сбросить фильтры">
                    <TextBlock Text="✕ Фильтр"/>
                </Button>

                <Separator Width="1"
                           Background="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="4,2"/>

                <Button Command="{Binding ClearSortCommand}"
                        Padding="10,4"
                        ToolTip.Tip="Сбросить сортировку">
                    <TextBlock Text="↕ Сортировка"/>
                </Button>

                <TextBlock VerticalAlignment="Center" Opacity="0.6" Margin="12,0,0,0">
                    <Run Text="Показано:"/>
                    <Run Text="{Binding Transactions.Count}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Opacity="0.75"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Transactions TreeDataGrid -->
        <TreeDataGrid Source="{Binding TransactionsSource}"
                      CanUserResizeColumns="True"
                      ShowColumnHeaders="True"
                      FontSize="13"/>

    </DockPanel>
</Window>
